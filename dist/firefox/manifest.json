{
  "manifest_version": 3,
  "name": "MindFulCloud",
  "version": "4.5",
  "description": "De-clutter your digital space across multiple platforms.",

  "permissions": ["storage", "tabs"],

  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.reddit.com/*",
    "*://*.twitter.com/*",
    "*://*.x.com/*",
    "*://*.pinterest.com/*"
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icons/icon48.png"
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.reddit.com/*",
        "*://*.twitter.com/*",
        "*://*.x.com/*",
        "*://*.pinterest.com/*"
      ],
      "js": ["content.js"],
      "css": [
        "styles/youtube-clean.css",
        "styles/reddit-clean.css",
        "styles/twitter-clean.css",
        "styles/pinterest-clean.css"
      ],
      "run_at": "document_start"
    }
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "mindful-new-v2@yourextension.com"
    }
  }
}
