{
  "manifest_version": 3,
  "name": "MindFulCloud",
  "version": "5.3.1",
  "description": "De-clutter your digital space across multiple platforms.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.reddit.com/*",
    "*://*.twitter.com/*",
    "*://*.x.com/*",
    "*://*.pinterest.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icons/icon48.png"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.reddit.com/*",
        "*://*.twitter.com/*",
        "*://*.x.com/*",
        "*://*.pinterest.com/*"
      ],
      "js": ["shared/settings.js", "content.js"],
      "css": [
        "styles/youtube/youtube-clean.css",
        "styles/youtube-music/base.css",
        "styles/youtube-music/minimal.css",
        "styles/youtube-music/focus.css",
        "styles/reddit/base.css",
        "styles/reddit/minimal.css",
        "styles/reddit/compact.css",
        "styles/reddit/focus.css",
        "styles/reddit/promoted-content.css",
        "styles/twitter/base.css",
        "styles/twitter/minimal.css",
        "styles/twitter/focus.css",
        "styles/twitter/zen.css",
        "styles/twitter/promoted-content.css",
        "styles/pinterest/base.css",
        "styles/pinterest/minimal.css",
        "styles/pinterest/dark.css",
        "styles/pinterest/promoted-content.css"
      ],
      "run_at": "document_start"
    }
  ]
}
